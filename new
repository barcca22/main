
mesicni_vyplata = []
hodinova_mzda=int(input("Zadejte hodinovou mzdu: "))
with open('vykaz.txt', encoding='utf-8') as file:
    for line in file:
        vyplata = int(line) * hodinova_mzda
        mesicni_vyplata.append(vyplata)
        print(f"Vyplata za mesic: {vyplata}")

with open('mesicni_vyplata.txt', mode='w', encoding='utf-8') as output_file:
    for vyplata in mesicni_vyplata:
        print(vyplata, file=output_file)
